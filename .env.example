# SafePay environment template

APP_NAME=SafePay
APP_ENV=development
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000/api/v1

# Frontend
NEXT_PUBLIC_APP_NAME=SafePay
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000
BACKEND_LOG_LEVEL=info

# Security / auth
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=7
PASSWORD_PEPPER=
OTP_CODE_LENGTH=6
OTP_TTL_SECONDS=300
DEVICE_FINGERPRINT_SALT=
BEHAVIORAL_TRUST_SCORE_TTL_SECONDS=300

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/safepay
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=safepay
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Cache / messaging
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Payments / wallet
DEFAULT_CURRENCY=INR
IDEMPOTENCY_KEY_TTL_SECONDS=86400

# SMS / email / OTP delivery
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=

# Behavioral / telemetry
TELEMETRY_MAX_EVENT_AGE_SECONDS=60

# ML service
ML_SERVICE_URL=http://localhost:8100
ML_MODEL_VERSION=local-dev
ML_XGBOOST_MODEL_PATH=/app/models/xgboost.json
ML_ISOLATION_FOREST_MODEL_PATH=/app/models/isolation_forest.joblib
ML_SHAP_BACKGROUND_DATA_PATH=/app/data/shap_background.json

# Blockchain / Hardhat
BLOCKCHAIN_NETWORK=hardhat
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_CHAIN_ID=31337
BLOCKCHAIN_PRIVATE_KEY=
FRAUD_REGISTRY_CONTRACT_ADDRESS=
REPUTATION_CONTRACT_ADDRESS=
BLOCKCHAIN_ENTITY_SALT=

# Federated learning
FL_SERVER_ADDRESS=0.0.0.0:8080
FL_SERVER_PORT=8080
FL_NUM_ROUNDS=5
FL_CLIENT_TIMEOUT_SECONDS=30

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_METRICS_PORT=9090

# External integrations / placeholders
WEBHOOK_SECRET=
SUPPORT_EMAIL=support@safepay.local
